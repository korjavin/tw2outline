# Required
OUTLINE_URL=https://your-outline-instance.example.com
OUTLINE_API_TOKEN=your_outline_api_token_here
OUTLINE_COLLECTION_ID=your_outline_collection_id_here

TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here
TW_USER=your_twitter_username_here

# Optional — defaults shown
TWITTER_REDIRECT_URL=http://localhost:8080/callback
CHECK_INTERVAL=1h
REMOVE_BOOKMARKS=false
CLEANUP_PROCESSED_BOOKMARKS=false
CALLBACK_PORT=8080
LOG_LEVEL=INFO

# ntfy notifications (optional)
NTFY_SERVER=http://ntfy:80
NTFY_TOPIC=tw2outline
NTFY_PORT=8082
NTFY_DOMAIN=ntfy.yourdomain.com
NTFY_USERNAME=
NTFY_PASSWORD=

# Traefik (optional, for domain-based deployment)
TRAEFIK_ENABLE=false
TW2OUTLINE_DOMAIN=tw2outline.yourdomain.com
